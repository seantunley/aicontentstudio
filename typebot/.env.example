# Typebot stack secrets — copy to typebot/.env (gitignored) and fill before bring-up.
# Open-source + local + free for your own use. No SMTP needed for a single operator: the login
# magic link prints to `docker logs typebot-builder` (grep for the http link), click it once,
# the session persists.

# --- database (Postgres) ---
POSTGRES_DB=typebot
POSTGRES_PASSWORD=change-me
# DATABASE_URL must embed the SAME password as POSTGRES_PASSWORD above.
DATABASE_URL=postgresql://postgres:change-me@typebot-db:5432/typebot

# --- core security ---
# ENCRYPTION_SECRET MUST be exactly 32 characters (256-bit key). Generate: openssl rand -hex 16
ENCRYPTION_SECRET=change-me-32-chars-exactly------
NEXTAUTH_SECRET=change-me-base64

# --- public URLs (browser-reachable on the LAN; baked at runtime by the Typebot images) ---
# Builder = the editor you work in (embedded in the studio at /flows). Viewer = where published bots run.
NEXTAUTH_URL=http://172.18.18.101:4011
NEXT_PUBLIC_VIEWER_URL=http://172.18.18.101:4012

# --- admin: this email auto-gets a Team workspace; use the operator's address ---
ADMIN_EMAIL=you@example.com

# --- email / login: this build has NO auth provider unless SMTP is configured, so we point it at a
#     local Mailpit sink. This ENABLES the magic-link login (do NOT set SMTP_AUTH_DISABLED — that
#     turns email login OFF). Mailpit accepts any/no auth and never sends externally; the operator
#     reads the login link in Mailpit's web inbox at http://172.18.18.101:4013. Free + fully local. ---
SMTP_HOST=typebot-mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USERNAME=studio
SMTP_PASSWORD=studio
NEXT_PUBLIC_SMTP_FROM=studio@localhost
