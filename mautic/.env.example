# Mautic stack secrets — copy to mautic/.env (gitignored) and fill before bring-up.
# The funnel engine is free + local; email DELIVERY needs an external SMTP relay (set in the
# Mautic UI after first run), and public landing pages/forms need a public URL.

# --- database (MariaDB) ---
MAUTIC_DB_ROOT_PASSWORD=change-me-root
MAUTIC_DB_NAME=mautic
MAUTIC_DB_USER=mautic
MAUTIC_DB_PASSWORD=change-me

# --- image tag: verify + pin to the current stable Mautic before bring-up ---
MAUTIC_TAG=5-apache

# --- admin login: created by the one-off `mautic:install` step (see docs/mautic-integration.md).
#     Stored here for reference after install; change MAUTIC_ADMIN_PASSWORD after first login. ---
MAUTIC_ADMIN_EMAIL=you@example.com
MAUTIC_ADMIN_PASSWORD=set-at-install

# --- email delivery (NOT local): set an SMTP relay / Amazon SES in Mautic Settings -> Email
#     after first run so campaign mail actually sends. ---
# (MAUTIC_TRUSTED_PROXIES is omitted — Mautic wants it as JSON e.g. ["10.0.0.0/8"]; set only behind a reverse proxy)
