# Mautic stack secrets — copy to mautic/.env (gitignored) and fill before bring-up.
# The funnel engine is free + local; email DELIVERY needs an external SMTP relay (set in the
# Mautic UI after first run, or via env), and public landing pages/forms need a public URL.

# --- database (MariaDB) ---
MAUTIC_DB_ROOT_PASSWORD=change-me-root
MAUTIC_DB_NAME=mautic
MAUTIC_DB_USER=mautic
MAUTIC_DB_PASSWORD=change-me

# --- image tag: verify + pin to the current stable Mautic before bring-up ---
MAUTIC_TAG=5-apache

# --- behind the LAN; widen/narrow as needed ---
MAUTIC_TRUSTED_PROXIES=0.0.0.0/0

# --- email delivery (NOT local): set an SMTP relay / Amazon SES so campaign mail actually sends.
#     Configure in Mautic Settings → Email after first run, or pre-seed here if your image supports it. ---
# MAUTIC_MAILER_DSN=smtp://user:pass@smtp.your-relay.com:587
