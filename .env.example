# AI Content Studio — environment template.  Copy to .env and adjust:  cp .env.example .env
# This file is COMMITTED; .env is gitignored. Put NO secrets here.
#
# IMPORTANT: Hermes's own secrets are NOT in this repo. The OpenAI login
# (ChatGPT Plus/Pro via Codex OAuth device-code) and the Telegram bot token are
# configured by `hermes setup` / `hermes model` and stored inside the container
# volume at ~/.hermes/ (auth.json + .env) — never here, never in git.

# Pinned Hermes image tag (plan §4a/§12 — pin a release, never use :latest).
# Bump deliberately after reading the release notes.
HERMES_IMAGE_TAG=v2026.6.5

# Host user that owns ~/.hermes and ./studio-data, so container-written files stay yours.
# Find yours with:  id -u   and   id -g   (use your LOGIN primary group, not a newgrp-elevated one).
HERMES_UID=1000
HERMES_GID=1000

# External heartbeat ping URL (plan §9b). Create a free check at https://healthchecks.io
# and paste its ping URL here when we wire the heartbeat (Phase 0 step 7). Leave blank until then.
HEALTHCHECK_URL=

# Postiz integration (Phase 1). The studio calls Postiz's public API to publish approved drafts;
# Postiz holds the platform OAuth tokens (§2c). API key is auto-generated by Postiz (Organization.apiKey),
# or Settings > Developers > Public API in the Postiz UI.
POSTIZ_API_URL=http://localhost:4007/api/public/v1
POSTIZ_API_KEY=

# Dashboard cockpit auth (Phase 1, §7a — single operator). Plaintext password is never stored.
#   DASH_PASSWORD_HASH_B64 = base64 of a bcrypt hash (base64 so its '$' chars don't break compose).
#   Generate: node -e "console.log(Buffer.from(require('bcryptjs').hashSync('YOURPASS',10)).toString('base64'))"
#   SESSION_SECRET = 32+ char random (iron-session cookie key): python3 -c 'import secrets;print(secrets.token_urlsafe(32))'
DASH_USER=
DASH_PASSWORD_HASH_B64=
SESSION_SECRET=

# Bot DM notifications from the dashboard (two-way loop). From ~/.hermes/.env.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
